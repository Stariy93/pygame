            self.kill() # \'d3\'e4\'e0\'eb\'ff\'e5\'ec, \'e5\'f1\'eb\'e8 \'e2\'fb\'eb\'e5\'f2\'e5\'eb\'e0 \'e7\'e0 \'fd\'ea\'f0\'e0\'ed\par
\par
