        keys = pygame.key.get_pressed()\par
        if keys[pygame.K_LEFT]: self.rect.x -= 5\par
        if keys[pygame.K_RIGHT]: self.rect.x += 5\par
\par
    def shoot(self):\par
        # \'d1\'ee\'e7\'e4\'e0\'e5\'ec \'ef\'f3\'eb\'fe \'e2 \'ea\'ee\'ee\'f0\'e4\'e8\'ed\'e0\'f2\'e0\'f5 \'f6\'e5\'ed\'f2\'f0\'e0 \'e8\'e3\'f0\'ee\'ea\'e0\par
