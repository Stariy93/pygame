    enemy = Enemy(100 + i * 120, 100)\par
    all_sprites.add(enemy)\par
    enemies.add(enemy)\par
\par
# --- \'c3\'cb\'c0\'c2\'cd\'db\'c9 \'d6\'c8\'ca\'cb ---\par
running = True\par
while running:\par
    for event in pygame.event.get():\par
        if event.type == pygame.QUIT:\par
            running = False\par
        elif event.type == pygame.KEYDOWN:\par
            if event.key == pygame.K_SPACE:\par
                player.shoot() # \'c2\'fb\'f1\'f2\'f0\'e5\'eb \'ef\'ee \'ef\'f0\'ee\'e1\'e5\'eb\'f3\par
\par
    # 1. \'ce\'e1\'ed\'ee\'e2\'eb\'ff\'e5\'ec \'eb\'ee\'e3\'e8\'ea\'f3 \'c2\'d1\'c5\'d5 \'ee\'e1\'fa\'e5\'ea\'f2\'ee\'e2 \'f0\'e0\'e7\'ee\'ec\par
    all_sprites.update()\par
\par
    # 2. \'cf\'f0\'ee\'e2\'e5\'f0\'ff\'e5\'ec \'f1\'f2\'ee\'eb\'ea\'ed\'ee\'e2\'e5\'ed\'e8\'ff \'ec\'e5\'e6\'e4\'f3 \'e3\'f0\'f3\'ef\'ef\'ee\'e9 \'ef\'f3\'eb\'fc \'e8 \'e3\'f0\'f3\'ef\'ef\'ee\'e9 \'e2\'f0\'e0\'e3\'ee\'e2\par
    # \'ce\'e1\'e5 \'e8\'f1\'f7\'e5\'e7\'ed\'f3\'f2 \'ef\'f0\'e8 \'ea\'e0\'f1\'e0\'ed\'e8\'e8 (True, True)\par
    hits = pygame.sprite.groupcollide(bullets, enemies, True, True)\par
    if hits:\par
        print("\'cf\'ee\'ef\'e0\'e4\'e0\'ed\'e8\'e5!")\par
\par
