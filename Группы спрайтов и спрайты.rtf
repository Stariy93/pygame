        all_sprites.add(bullet)\par
        bullets.add(bullet)\par
\par
class Bullet(pygame.sprite.Sprite):\par
    def __init__(self, x, y):\par
        super().__init__()\par
        self.image = pygame.Surface((10, 20))\par
        self.image.fill("yellow")\par
        self.rect = self.image.get_rect(center=(x, y))\par
\par
    def update(self):\par
        self.rect.y -= 10 # \'cf\'f3\'eb\'ff \'eb\'e5\'f2\'e8\'f2 \'e2\'e2\'e5\'f0\'f5\par
