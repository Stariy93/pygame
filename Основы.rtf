\par
# \'ca\'f0\'f3\'e3 (\'ef\'ee\'e2\'e5\'f0\'f5\'ed\'ee\'f1\'f2\'fc, \'f6\'e2\'e5\'f2, \'f6\'e5\'ed\'f2\'f0, \'f0\'e0\'e4\'e8\'f3\'f1)\par
pygame.draw.circle(screen, "blue", (400, 300), 50)\par
\par
# \'cb\'e8\'ed\'e8\'ff (\'ef\'ee\'e2\'e5\'f0\'f5\'ed\'ee\'f1\'f2\'fc, \'f6\'e2\'e5\'f2, \'ed\'e0\'f7\'e0\'eb\'ee, \'ea\'ee\'ed\'e5\'f6, \'f2\'ee\'eb\'f9\'e8\'ed\'e0)\par
pygame.draw.line(screen, "green", (0, 0), (800, 600), 5)\par
